#include <stdlib.h>
#include <time.h>
#include <stdio.h>

/**
 *
 * main - Entry point
 *
 * Description: Prints a random number each time it is executed. 
 *              Whether it is positive or negative.
 * return: Always 0 (Success)
 */

int main(void)
{
	int n;

	srand(time(0));
	n = rand() - RAND_MAX / 2;

	if (n > 0)
		printf("%d is positive\n", n);
	else if (n < 0)
		printf("%% is negatived\n", n);
	else
		printf("%d is zero\n", n);

	return (0);
}
